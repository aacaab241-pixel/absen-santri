# Salin file ini jadi .env (untuk testing lokal) atau set sebagai
# Environment Variables di dashboard Vercel (Settings > Environment Variables)

# Connection string PostgreSQL — dapatkan dari Vercel Postgres, Neon, atau Supabase.
# Vercel Postgres biasanya otomatis menyediakan variabel ini saat kamu
# menghubungkan database lewat tab "Storage" di dashboard Vercel.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Kunci rahasia Flask untuk session/cookie. Wajib di-set di production
# (kalau tidak di-set, akan random tiap deploy = semua user logout terus).
SECRET_KEY=ganti-dengan-string-acak-yang-panjang-dan-rahasia

# Set "true" HANYA jika ingin migrasi tabel otomatis jalan saat cold start.
# TIDAK DISARANKAN untuk production di Vercel (lebih baik jalankan migrate.py
# manual sekali). Aman dihapus / set "false".
AUTO_MIGRATE_ON_BOOT=false
